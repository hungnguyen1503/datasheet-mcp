# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment / secrets
mcp/.env
!mcp/.env.example

# LanceDB local vector store (large binary, rebuild with ingest)
data/.lancedb/

# MinerU intermediate output (auto-regenerated)
data/*/_mineru_raw/

# LLM extraction cache (resumable, can be regenerated)
data/*/.extract_cache.json

# Source PDFs (keep these out of git — add your own)
data/*/source.pdf

# Extracted JSON artefacts (regenerated by ingest)
data/*/registers.json
data/*/pins.json
data/*/catalog.json

# MinerU markdown output (regenerated by Stage 1)
data/*/MD/

# Test / editor artefacts
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code
.claude/worktrees/

# CodeGraph index (local tooling, not part of the project)
.codegraph/

# Root-level PDF files (put your datasheets in data/<PART>/source.pdf instead)
*.pdf
