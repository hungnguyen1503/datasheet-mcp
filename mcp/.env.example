# ── Local vector store (LanceDB — no server needed) ──────────────────────────
# Default: data/.lancedb/ inside the repo.
# DS_DB_PATH=./data/.lancedb   # relative to repo root, or absolute path

# ── MCP transport ─────────────────────────────────────────────────────────────
DS_TRANSPORT=stdio          # stdio | streamable-http | sse
DS_HOST=0.0.0.0
DS_PORT=8002

# ── Access control (optional) ─────────────────────────────────────────────────
DS_API_KEYS=
DS_SERVER_URL=https://ds.example.com

# ── Embedding model ───────────────────────────────────────────────────────────
# CPU-friendly default (384-dim, ~130 MB). GPU users may prefer bge-base or bge-large.
DS_EMBED_MODEL=BAAI/bge-small-en-v1.5
DS_EMBED_QUERY_PREFIX=Represent this sentence for searching relevant passages:
# DS_EMBED_DEVICE=cuda          # cuda | cpu (auto-detected if unset)
# DS_EMBED_BATCH_SIZE=32        # default: 256 on GPU, 32 on CPU

# ── Optional cross-encoder reranker ──────────────────────────────────────────
# DS_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── MinerU device (Stage 1 — auto-detected from CUDA availability) ────────────
# MINERU_DEVICE_MODE=cuda       # override: cuda | cpu

# ── Windows console UTF-8 ─────────────────────────────────────────────────────
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
